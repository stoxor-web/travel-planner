rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSignedInUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'lucas.scribe01@gmail.com';
    }

    function hasValidBackupShape() {
      return request.resource.data.keys().hasOnly([
        'ownerUid',
        'ownerEmail',
        'schema',
        'schemaVersion',
        'clientUpdatedAt',
        'updatedAt',
        'state'
      ])
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.schema == 'travelPlannerState'
      && request.resource.data.schemaVersion == 1
      && request.resource.data.state is map;
    }

    function hasValidCommunityOwner() {
      return signedIn()
        && request.resource.data.schema == 'communityTrip'
        && request.resource.data.schemaVersion == 1
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.country is string
        && request.resource.data.category is string
        && request.resource.data.trip is map;
    }

    function voteOnlyUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'votes', 'upVotes', 'downVotes', 'trendScore', 'updatedAt'
        ]);
    }

    match /travelPlannerUsers/{userId} {
      allow read: if isSignedInUser(userId);
      allow create: if isSignedInUser(userId) && hasValidBackupShape();
      allow update: if isSignedInUser(userId)
        && resource.data.ownerUid == request.auth.uid
        && hasValidBackupShape();
      allow delete: if isSignedInUser(userId);
    }

    match /communityTrips/{tripId} {
      allow read: if true;

      allow create: if hasValidCommunityOwner();

      allow update: if voteOnlyUpdate()
        || (signedIn() && resource.data.ownerUid == request.auth.uid && hasValidCommunityOwner())
        || isAdmin();

      allow delete: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
