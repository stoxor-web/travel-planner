rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedInUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'lucas.scribe01@gmail.com';
    }

    function hasValidBackupShape() {
      return request.resource.data.keys().hasOnly([
        'ownerUid',
        'ownerEmail',
        'schema',
        'schemaVersion',
        'clientUpdatedAt',
        'updatedAt',
        'state'
      ])
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.schema == 'travelPlannerState'
      && request.resource.data.schemaVersion == 1
      && request.resource.data.state is map;
    }

    function hasValidCommunityShape() {
      return request.resource.data.keys().hasOnly([
        'schema', 'schemaVersion', 'id', 'ownerUid', 'ownerEmail', 'ownerName',
        'sourceTripId', 'title', 'country', 'area', 'category', 'style', 'pace',
        'interests', 'description', 'coverImage', 'currency', 'publicBudget',
        'hideBudget', 'hideNotes', 'allowCopy', 'durationDays', 'stepsCount',
        'highlights', 'trip', 'votes', 'upVotes', 'downVotes', 'trendScore',
        'publishedAt', 'updatedAt'
      ])
      && request.resource.data.schema == 'communityTrip'
      && request.resource.data.schemaVersion == 1
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.title is string
      && request.resource.data.country is string
      && request.resource.data.category is string
      && request.resource.data.trip is map;
    }

    match /travelPlannerUsers/{userId} {
      allow read: if isSignedInUser(userId);

      allow create: if isSignedInUser(userId)
        && hasValidBackupShape();

      allow update: if isSignedInUser(userId)
        && resource.data.ownerUid == request.auth.uid
        && hasValidBackupShape();

      allow delete: if isSignedInUser(userId);
    }

    match /communityTrips/{tripId} {
      allow read: if true;

      allow create: if request.auth != null
        && hasValidCommunityShape();

      allow update: if request.auth != null && (
        (resource.data.ownerUid == request.auth.uid && hasValidCommunityShape())
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'votes', 'upVotes', 'downVotes', 'trendScore', 'updatedAt'
        ])
      );

      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
