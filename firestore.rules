rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }
    function isAdmin() { return signedIn() && request.auth.token.email == 'lucas.scribe01@gmail.com'; }

    match /travelPlannerUsers/{userId} {
      allow read, write, delete: if isOwner(userId);
    }

    match /sharedTrips/{shareId} {
      allow read: if resource.data.visibility == 'public'
        || (signedIn() && (resource.data.ownerUid == request.auth.uid
        || request.auth.token.email in resource.data.allowedEmails));
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /communityTrips/{tripId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
