rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(userId) { return signedIn() && request.auth.uid == userId; }
    function isAdmin() { return signedIn() && request.auth.token.email == 'lucas.scribe01@gmail.com'; }

    match /travelPlannerUsers/{userId} {
      allow read, create, update, delete: if owner(userId);
    }

    match /communityTrips/{tripId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
